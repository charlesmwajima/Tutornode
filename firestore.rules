rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidFeedback(data) {
      return data.keys().hasAll(['topic', 'quality_score', 'relevance_score', 'timestamp']) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.topic is string && data.topic.size() <= 500 &&
             data.quality_score is int && data.quality_score >= 1 && data.quality_score <= 5 &&
             data.relevance_score is int && data.relevance_score >= 1 && data.relevance_score <= 5 &&
             data.timestamp == request.time &&
             (data.get('comments', '') is string && data.get('comments', '').size() <= 2000) &&
             (data.get('teacher_dialogue', '') is string && data.get('teacher_dialogue', '').size() <= 20000) &&
             (data.get('userId', '') is string && data.get('userId', '').size() <= 128);
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['topic', 'timestamp']) &&
             data.topic is string && data.topic.size() <= 1000 &&
             data.timestamp == request.time &&
             (data.get('whiteboard_notes', '') is string && data.get('whiteboard_notes', '').size() <= 100000) &&
             (data.get('teacher_dialogue', '') is string && data.get('teacher_dialogue', '').size() <= 20000);
    }

    match /feedbacks/{feedbackId} {
      // Create: Anyone can submit feedback, but it must be valid
      allow create: if isValidId(feedbackId) && isValidFeedback(incoming());
      
      // Read/Update/Delete: Denied for standard users
      allow get: if false;
      allow list: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /lessons/{lessonId} {
      // Allow creation of lessons. Auto-generated IDs are handled by the document pattern.
      // We allow anyone to create a lesson for now, but validate the content.
      allow create: if isValidId(lessonId) && isValidLesson(incoming());
      // Allow reading lessons for history
      allow list: if true;
      allow get: if true;
      allow update, delete: if false;
    }
  }
}
